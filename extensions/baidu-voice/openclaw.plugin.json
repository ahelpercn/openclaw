{
  "id": "baidu-voice",
  "name": "Baidu Voice",
  "description": "百度语音设备深度集成 — 24小时AI员工",
  "version": "1.0.0",
  "configSchema": {
    "type": "object",
    "additionalProperties": true,
    "properties": {
      "devices": {
        "type": "array",
        "items": { "type": "object" }
      },
      "baidu": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "appId": { "type": "string" },
          "wsUrl": { "type": "string" },
          "audioCodec": { "type": "string" }
        }
      },
      "openclaw": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "gatewayUrl": { "type": "string" },
          "notifyChannels": { "type": "array", "items": { "type": "string" } }
        }
      },
      "features": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "enableScheduledTasks": { "type": "boolean" },
          "autoReconnect": { "type": "boolean" }
        }
      }
    }
  }
}
